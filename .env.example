# DGRINGO — environment config
# Copy to ".env" and fill in. Vite only exposes vars prefixed with VITE_ to the app.

# Telnyx integration mode: "mock" (no backend needed) or "live"
VITE_TELNYX_MODE=mock

# Base path the app calls in live mode. This must point at YOUR backend proxy,
# NOT api.telnyx.com (the secret key must never reach the browser).
VITE_API_BASE=/api/telnyx

# Optional defaults used when ordering numbers / sending SMS in live mode
VITE_TELNYX_MESSAGING_PROFILE_ID=
VITE_TELNYX_CONNECTION_ID=

# ---- SERVER-SIDE ONLY (used by server/telnyx-proxy.mjs, never by the app) ----
# Your Telnyx V2 API key. KEEP SECRET. Do not prefix with VITE_.
TELNYX_API_KEY=KEY_xxxxxxxxxxxxxxxxxxxxxxxx
# Port the proxy listens on
TELNYX_PROXY_PORT=8787
